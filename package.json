{
  "name": "@architprasar/md4ai",
  "version": "0.1.2",
  "description": "AI-friendly rich markdown renderer — extended markdown syntax that renders to interactive UI",
  "type": "module",
  "main": "./dist/md4ai.umd.cjs",
  "module": "./dist/md4ai.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/md4ai.js",
      "require": "./dist/md4ai.umd.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "files": [
    "dist",
    "mcp-server.mjs"
  ],
  "bin": {
    "md4ai-mcp": "./mcp-server.mjs"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.runtime.json && tsc --emitDeclarationOnly --declarationDir dist",
    "build:demo": "npm --prefix examples/demo run build",
    "dev": "cd examples/demo && npm run dev",
    "test": "tsc -p tsconfig.test.json && node --test test/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "check": "node scripts/check.mjs"
  },
  "keywords": [
    "markdown",
    "ai",
    "renderer",
    "react",
    "rich-text"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/architprasar/md4ai.git"
  },
  "homepage": "https://github.com/architprasar/md4ai#readme",
  "bugs": {
    "url": "https://github.com/architprasar/md4ai/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "peerDependencies": {
    "chart.js": ">=4",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "chart.js": {
      "optional": true
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "chart.js": "^4.4.9",
    "js-tiktoken": "^1.0.21",
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vite-plugin-dts": "^4.5.4"
  }
}
